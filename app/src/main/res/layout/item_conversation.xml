<?xml version="1.0" encoding="utf-8"?>
<!--
    Single conversation row in the conversation list.

    The root LinearLayout is the single focusable unit — the entire row
    lights up with the D-Pad focus ring when selected.

    Layout:
      [Avatar]  [Name ────────── Date]
                [Snippet ─── Unread#]
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/conversation_item_height"
    android:background="@android:color/transparent"
    android:clickable="false"
    android:focusable="false"
    android:focusableInTouchMode="false"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/conversation_padding_h"
    android:paddingEnd="@dimen/conversation_padding_h"
    android:paddingTop="@dimen/conversation_padding_v"
    android:paddingBottom="@dimen/conversation_padding_v">

    <LinearLayout
        android:id="@+id/conversation_click_area"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/item_focusable_bg"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/conversation_padding_h"
        android:paddingEnd="@dimen/conversation_padding_h"
        android:nextFocusRight="@id/btn_conversation_menu">

        <!-- Avatar (contact photo or initial letter) -->
        <FrameLayout
            android:layout_width="@dimen/avatar_size"
            android:layout_height="@dimen/avatar_size"
            android:focusable="false">

        <!-- Photo (loaded by Glide when available) -->
        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="@dimen/avatar_size"
            android:layout_height="@dimen/avatar_size"
            android:contentDescription="@null"
            android:focusable="false"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <!-- Fallback: coloured circle with initial letter -->
        <TextView
            android:id="@+id/tv_avatar_letter"
            android:layout_width="@dimen/avatar_size"
            android:layout_height="@dimen/avatar_size"
            android:background="@drawable/avatar_bg"
            android:focusable="false"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/avatar_text_size"
            android:textStyle="bold" />

        </FrameLayout>

        <!-- Text content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/padding_small"
            android:layout_weight="1"
            android:focusable="false"
            android:gravity="center_vertical"
            android:orientation="vertical">

        <!-- Row 1: Name + Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:focusable="false"
                android:maxLines="1"
                android:textColor="@color/conversationTitle"
                android:textSize="@dimen/text_size_normal" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:textColor="@color/conversationDate"
                android:textSize="@dimen/text_size_small" />

        </LinearLayout>

        <!-- Row 2: Snippet + Unread badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_snippet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:focusable="false"
                android:maxLines="1"
                android:textColor="@color/conversationSnippet"
                android:textSize="@dimen/text_size_small" />

            <TextView
                android:id="@+id/tv_unread_count"
                style="@style/UnreadBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_tiny"
                android:focusable="false"
                android:visibility="gone" />

        </LinearLayout>

        </LinearLayout>

        <!-- Pin indicator -->
        <ImageView
            android:id="@+id/iv_pinned"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginStart="@dimen/padding_tiny"
            android:contentDescription="@null"
            android:focusable="false"
            android:src="@drawable/ic_pin"
            android:visibility="gone" />

        <!-- Mute indicator -->
        <ImageView
            android:id="@+id/iv_muted"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginStart="2dp"
            android:contentDescription="@null"
            android:focusable="false"
            android:src="@drawable/ic_mute"
            android:visibility="gone" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_conversation_menu"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="@dimen/padding_small"
        android:background="@drawable/button_focusable_bg"
        android:contentDescription="@string/conversation_options"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:nextFocusLeft="@id/conversation_click_area"
        android:scaleType="center"
        android:src="@drawable/ic_more_vert"
        android:tint="@color/toolbarIcon" />

</LinearLayout>
