<?xml version="1.0" encoding="utf-8"?>
<!--
    New conversation screen (contacts-first).

    D-Pad flow:
      Toolbar (Back) → DOWN → et_recipient
      et_recipient   → DOWN → btn_send
      btn_send       → UP   → et_recipient
      et_recipient   → UP   → Toolbar
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:background="@color/toolbarBg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/toolbar_padding_h"
        android:paddingEnd="@dimen/toolbar_padding_h">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/toolbar_button_width"
            android:layout_height="@dimen/toolbar_height"
            android:background="@drawable/button_focusable_bg"
            android:contentDescription="@string/back"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@id/et_recipient"
            android:scaleType="center"
            android:src="@drawable/ic_back"
            android:tint="@color/toolbarIcon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:focusable="false"
            android:paddingStart="@dimen/padding_small"
            android:text="@string/new_conversation"
            android:textColor="@color/toolbarText"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Instructional hint for new threads (wraps across lines) -->
    <TextView
        android:id="@+id/tv_recipient_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/padding_medium"
        android:paddingEnd="@dimen/padding_medium"
        android:paddingTop="@dimen/padding_small"
        android:text="@string/new_thread_hint"
        android:textColor="@color/composeHint"
        android:textSize="@dimen/text_size_normal"
        android:maxLines="2"
        android:visibility="visible" />

    <!-- To: field -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/padding_medium"
        android:paddingEnd="@dimen/padding_medium"
        android:paddingTop="@dimen/padding_small"
        android:paddingBottom="@dimen/padding_small">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:text="To: "
            android:textColor="@color/conversationDate"
            android:textSize="@dimen/text_size_normal" />

        <EditText
            android:id="@+id/et_recipient"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:hint="@string/enter_recipients_hint"
            android:imeOptions="actionDone"
            android:inputType="textNoSuggestions"
            android:maxLines="1"
            android:nextFocusDown="@id/btn_send"
            android:nextFocusUp="@id/btn_back"
            android:singleLine="true"
            android:textColor="@color/colorOnBackground"
            android:textColorHint="@color/composeHint"
            android:textSize="@dimen/text_size_normal" />

            <TextView
                android:id="@+id/btn_add_recipient"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="@dimen/padding_small"
                android:background="@drawable/button_focusable_bg"
                android:contentDescription="@string/add_recipient"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:nextFocusUp="@id/btn_back"
                android:nextFocusDown="@id/btn_send"
                android:text="+"
                android:textColor="@color/colorOnBackground"
                android:textSize="20sp"
                android:textStyle="bold" />

    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/recipient_chips_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        android:fillViewport="true"
        android:descendantFocusability="afterDescendants"
        android:paddingStart="@dimen/padding_medium"
        android:paddingEnd="@dimen/padding_medium"
        android:paddingBottom="@dimen/padding_small"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/recipient_chips_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Contact type-ahead suggestions -->
    <ListView
        android:id="@+id/lv_suggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        android:divider="@color/divider"
        android:dividerHeight="@dimen/divider_height"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:visibility="gone" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:background="@color/divider" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/colorBackground" />

    <!-- Next bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/compose_bar_height"
        android:background="@color/composeBg"
        android:gravity="center_vertical|end"
        android:orientation="horizontal"
        android:paddingStart="@dimen/compose_padding"
        android:paddingEnd="@dimen/compose_padding">

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="@dimen/compose_button_size"
            android:layout_height="@dimen/compose_button_size"
            android:background="@drawable/button_focusable_bg"
            android:contentDescription="@string/next"
            android:enabled="false"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusUp="@id/et_recipient"
            android:scaleType="center"
            android:src="@drawable/ic_send"
            android:tint="@color/sendButtonDisabled" />

    </LinearLayout>

</LinearLayout>
