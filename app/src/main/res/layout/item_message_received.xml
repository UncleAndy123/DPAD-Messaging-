<?xml version="1.0" encoding="utf-8"?>
<!--
    Received message bubble (left-aligned).
    Shows sender name above the bubble for group conversations.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:focusable="false"
    android:gravity="start"
    android:orientation="vertical"
    android:paddingTop="@dimen/bubble_margin_v"
    android:paddingBottom="@dimen/bubble_margin_v">

    <!-- Sender name (visible only in group conversations) -->
    <TextView
        android:id="@+id/tv_sender_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/bubble_margin_h"
        android:layout_marginBottom="@dimen/bubble_sender_margin_top"
        android:focusable="false"
        android:textColor="@color/colorSecondary"
        android:textSize="@dimen/text_size_small"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/bubble_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/bubble_margin_h"
        android:background="@drawable/bubble_received"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:orientation="vertical"
        android:paddingStart="@dimen/bubble_padding_h"
        android:paddingEnd="@dimen/bubble_padding_h"
        android:paddingTop="@dimen/bubble_padding_v"
        android:paddingBottom="@dimen/bubble_padding_v">

        <TextView
            android:id="@+id/tv_body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:textColor="@color/bubbleReceivedText"
            android:textIsSelectable="false"
            android:textSize="@dimen/text_size_normal" />

        <!-- MMS image attachment -->
        <ImageView
            android:id="@+id/iv_attachment"
            android:layout_width="140dp"
            android:layout_height="105dp"
            android:layout_marginTop="@dimen/padding_tiny"
            android:focusable="false"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:textColor="#88FFFFFF"
            android:textSize="@dimen/text_size_small" />

    </LinearLayout>

</LinearLayout>
