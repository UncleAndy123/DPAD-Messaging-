<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:background="@color/toolbarBg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/toolbar_padding_h"
        android:paddingEnd="@dimen/toolbar_padding_h">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="@dimen/toolbar_button_width"
            android:layout_height="@dimen/toolbar_height"
            android:background="@drawable/button_focusable_bg"
            android:contentDescription="@string/back"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scaleType="center"
            android:src="@drawable/ic_back"
            android:tint="@color/toolbarIcon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:focusable="false"
            android:paddingStart="@dimen/padding_small"
            android:text="@string/conversation_details"
            android:textColor="@color/toolbarText"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Details content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <!-- Contact name row -->
            <TextView
                android:id="@+id/tv_contact_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/padding_small"
                android:textColor="@color/conversationTitle"
                android:textSize="@dimen/text_size_large"
                android:textStyle="bold" />

            <!-- Participants list (populated dynamically) -->
            <LinearLayout
                android:id="@+id/participant_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/padding_medium" />

            <!-- Action: Rename conversation -->
            <TextView
                android:id="@+id/btn_rename"
                android:layout_width="match_parent"
                android:layout_height="@dimen/conversation_item_height"
                android:background="@drawable/item_focusable_bg"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center_vertical"
                android:text="@string/rename_conversation"
                android:textColor="@color/colorOnBackground"
                android:textSize="@dimen/text_size_normal" />

            <!-- Action: Block -->
            <TextView
                android:id="@+id/btn_block"
                android:layout_width="match_parent"
                android:layout_height="@dimen/conversation_item_height"
                android:background="@drawable/item_focusable_bg"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center_vertical"
                android:text="@string/block"
                android:textColor="@color/statusFailed"
                android:textSize="@dimen/text_size_normal" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
