<?xml version="1.0" encoding="utf-8"?>
<!-- Background for the compose EditText field -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/composeInputBg"/>
            <stroke android:width="@dimen/focus_border_width" android:color="@color/focus_border"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/composeInputBg"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</selector>
