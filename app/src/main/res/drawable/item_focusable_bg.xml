<?xml version="1.0" encoding="utf-8"?>
<!--
    Focus selector for full-width list items (conversations, settings rows).
    Slightly different shape: no corner radius on a full-width row.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:state_pressed="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/focus_highlight"/>
            <stroke android:width="@dimen/focus_border_width" android:color="@color/focus_border"/>
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1A03DAC5"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
</selector>
