<?xml version="1.0" encoding="utf-8"?>
<!-- Sent message bubble: rounded on all corners except bottom-right -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/bubbleSentBg"/>
            <stroke android:width="@dimen/focus_border_width" android:color="@color/focus_border_sent"/>
            <corners
                android:topLeftRadius="@dimen/bubble_corner_radius"
                android:topRightRadius="@dimen/bubble_corner_radius"
                android:bottomLeftRadius="@dimen/bubble_corner_radius"
                android:bottomRightRadius="2dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bubbleSentBg"/>
            <corners
                android:topLeftRadius="@dimen/bubble_corner_radius"
                android:topRightRadius="@dimen/bubble_corner_radius"
                android:bottomLeftRadius="@dimen/bubble_corner_radius"
                android:bottomRightRadius="2dp"/>
        </shape>
    </item>
</selector>
